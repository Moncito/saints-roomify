# ─────────────────────────────────────────────────────────────────────────────
# Roomify — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Current (Puter Cloud Platform) ───────────────────────────────────────────
# URL of your deployed Puter Worker (project management API).
# Deploy lib/puter.worker.js from your Puter dashboard to obtain this value.
VITE_PUTER_WORKER_URL=https://your-worker-name.puter.work


# ── SaaS — Stripe Payments ───────────────────────────────────────────────────
# Server-side secret key (never expose to the client).
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret (from the Stripe dashboard → Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_...
# Client-side publishable key (safe to expose; prefixed with VITE_ for Vite).
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...


# ── SaaS — Database ──────────────────────────────────────────────────────────
# Primary database connection string (PostgreSQL recommended for SaaS).
# Examples:
#   PostgreSQL (Supabase / Neon / Railway):
#     DATABASE_URL=postgresql://user:password@host:5432/roomify
#   SQLite (local development only):
#     DATABASE_URL=file:./dev.db
DATABASE_URL=postgresql://user:password@localhost:5432/roomify


# ── SaaS — Authentication (if moving beyond Puter auth) ─────────────────────
# Secret used to sign JWT session tokens.  Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here
# Canonical URL of the deployed app (no trailing slash).
AUTH_URL=https://roomify.yourdomain.com

# OAuth providers (add as needed)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=


# ── SaaS — Email (transactional mail for billing receipts, welcome emails) ───
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_...
EMAIL_FROM=noreply@yourdomain.com


# ── SaaS — Feature Flags ─────────────────────────────────────────────────────
# Set to "true" to enable billing/subscription gating in the UI.
VITE_ENABLE_BILLING=false
# Set to "true" to show the upgrade / pricing page link in the navbar.
VITE_ENABLE_PRICING_PAGE=false
